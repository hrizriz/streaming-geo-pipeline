# Salin ke credentials.env (file itu di-gitignore).
# Isi kredensial & sesuaikan host/port jika kamu ubah docker-compose.

# --- Link akses (buka di browser / untuk dokumentasi) ---
FLINK_UI_URL=http://localhost:8081
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_S3_API_URL=http://localhost:9000
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_BOOTSTRAP_INTERNAL=kafka:29092
ZOOKEEPER_URL=localhost:2181

# --- Kredensial MinIO (service minio + harus sama dengan fs.s3a di docker-compose untuk Flink -> MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=ganti-dengan-password-kuat

# --- Iceberg (Postgres catalog; skrip python/curated_to_iceberg.py dari host) ---
# ICEBERG_JDBC_URI=postgresql+psycopg2://iceberg:iceberg@127.0.0.1:5432/iceberg

# --- Opsional: URL layanan BI / query ---
# TRINO_HTTP_URL=http://localhost:8082
# METABASE_URL=http://localhost:3030
# PROMETHEUS_URL=http://localhost:9090
# GRAFANA_URL=http://localhost:3010
# LOKI_URL=http://localhost:3100

# Grafana: set sebelum docker compose jika pakai substitusi ${GRAFANA_ADMIN_PASSWORD:-admin}
# GRAFANA_ADMIN_PASSWORD=admin

# --- Stack health agent (python -m stack_health_agent) ---
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# STACK_AGENT_ROOT=path-ke-root-repo (default: otomatis)
# STACK_AGENT_HOST=127.0.0.1
# STACK_ALERT_COOLDOWN_SEC=300
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
